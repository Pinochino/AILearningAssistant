{
  "name": "server",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/server.ts",
  "license": "MIT",
  "scripts": {
    "dev": "nodemon --exec tsx src/server.ts",
    "start": "node dist/server.js",
    "build": "rimraf ./dist && tsc && tsc-alias",
    "test:api": "ts-node src/test/api-test.ts",
    "test:socket": "ts-node src/test/socket-test.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "prepare": "husky",
    "seed": "tsx src/data/seed.ts",
    "dev:ai-service": "tsx src/ai-service/server.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@huggingface/hub": "^2.6.4",
    "@huggingface/inference": "^4.8.0",
    "@huggingface/transformers": "^3.7.3",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/express-handlebars": "^6.0.2",
    "@types/passport-google-oauth2": "^0.1.10",
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.6.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "body-parser": "^2.2.0",
    "cloudinary": "^2.7.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cron": "^4.3.3",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "express-handlebars": "^8.0.3",
    "express-openapi": "^12.1.3",
    "express-rate-limit": "^8.1.0",
    "express-session": "^1.18.2",
    "helmet": "^8.1.0",
    "husky": "^9.1.7",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "lint-staged": "^16.1.6",
    "mongodb": "^6.19.0",
    "mongoose": "^8.18.1",
    "mongoose-delete": "^1.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.6",
    "nodemailer-express-handlebars": "^7.0.0",
    "passport": "^0.7.0",
    "passport-google-oauth2": "^0.2.0",
    "redis": "^5.8.2",
    "socket.io": "^4.8.1",
    "tsconfig-paths": "^4.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/bcrypt": "^6.0.0",
    "@types/body-parser": "^1.19.6",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.18.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose-delete": "^1.0.6",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.5.2",
    "@types/nodemailer": "^7.0.1",
    "@types/nodemailer-express-handlebars": "^4.0.5",
    "@types/passport": "^1.0.17",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.3.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.43.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm test",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "lint-staged": {
    "*.js": [
      "eslint — fix",
      "prettier — write",
      "git add"
    ]
  }
}