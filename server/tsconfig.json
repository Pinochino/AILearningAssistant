{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2023",
    "outDir": "dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"]
    },
    "types": ["node", "express", "passport"]
  },
  "files": ["src/type.d.ts"],
  "include": [
    "src/server.ts",
    "src/configs/webConfigs.ts",
    "src/database/**/*.ts",
    "src/data/seed.ts",
    "src/models/**/*.ts",
    "src/routes/**/*.ts",
    "src/services/classes.services.ts",
    "src/types/**/*.ts",
    "src/utils/**/*.ts"
  ],
  "exclude": [
    "src/configs/passport.ts",
    "src/controllers/AuthController.ts",
    "src/routers/authRouter.ts",
    "src/services/authService.ts",
    "src/crons/**/*",
    "src/routers/routers.ts"
  ],
  "typeRoots": ["./node_modules/@types", "./src/types"]
}